@model CertificatesViewModel
@{
    ViewData["Title"] = "Certificates & Awards";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Certificates & Awards</h1>
        <p class="lead text-muted">Professional certifications and recognitions</p>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-pills justify-content-center mb-5" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.ActiveTab == "certificates" ? "active" : "")"
                    id="certificates-tab" data-bs-toggle="tab" data-bs-target="#certificates"
                    type="button" role="tab">
                <i class="bi bi-award me-2"></i>Certificates
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.ActiveTab == "awards" ? "active" : "")"
                    id="awards-tab" data-bs-toggle="tab" data-bs-target="#awards"
                    type="button" role="tab">
                <i class="bi bi-trophy me-2"></i>Awards
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content">
        <!-- Certificates Tab -->
        <div class="tab-pane fade @(Model.ActiveTab == "certificates" ? "show active" : "")"
             id="certificates" role="tabpanel">
            @if (!Model.Certificates.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-award display-1 text-muted"></i>
                    <p class="lead text-muted mt-3">No certificates added yet.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var cert in Model.Certificates)
                    {
                        <div class="col-md-6 col-lg-4">
                            <a asp-action="Detail" asp-route-slug="@cert.Slug" class="text-decoration-none">
                                <div class="card h-100 certificate-card">
                                    @if (!string.IsNullOrEmpty(cert.ImagePath))
                                    {
                                        <img src="@cert.ImagePath" class="card-img-top" alt="@cert.Title" style="height: 180px; object-fit: contain; padding: 1rem; background: rgba(255,255,255,0.05);">
                                    }
                                    else
                                    {
                                        <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 180px; background: rgba(255,255,255,0.05);">
                                            <i class="bi bi-award display-3 text-primary"></i>
                                        </div>
                                    }
                                    <div class="card-body">
                                        <h5 class="card-title text-white">@cert.Title</h5>
                                        <p class="text-muted mb-1">
                                            <i class="bi bi-building me-1"></i> @cert.Issuer
                                        </p>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar me-1"></i> @cert.DateEarned.ToString("MMM yyyy")
                                        </small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Awards Tab -->
        <div class="tab-pane fade @(Model.ActiveTab == "awards" ? "show active" : "")"
             id="awards" role="tabpanel">
            @if (!Model.Awards.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-trophy display-1 text-muted"></i>
                    <p class="lead text-muted mt-3">No awards added yet.</p>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        @foreach (var award in Model.Awards)
                        {
                            <div class="card mb-4">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-auto">
                                            @if (!string.IsNullOrEmpty(award.ImagePath))
                                            {
                                                <img src="@award.ImagePath" alt="@award.Title" style="width: 80px; height: 80px; object-fit: contain;">
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded" style="width: 80px; height: 80px;">
                                                    <i class="bi bi-trophy display-5 text-primary"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="col">
                                            <h5 class="mb-1">@award.Title</h5>
                                            @if (!string.IsNullOrEmpty(award.GivenBy))
                                            {
                                                <p class="text-muted mb-1">
                                                    <i class="bi bi-person-badge me-1"></i> @award.GivenBy
                                                </p>
                                            }
                                            <small class="text-muted">
                                                <i class="bi bi-calendar me-1"></i> @award.DateReceived.ToString("MMM yyyy")
                                            </small>
                                            @if (!string.IsNullOrEmpty(award.Description))
                                            {
                                                <p class="mt-2 mb-0">@award.Description</p>
                                            }
                                            @if (!string.IsNullOrEmpty(award.Url))
                                            {
                                                <a href="@award.Url" target="_blank" class="btn btn-sm btn-outline-primary mt-2">
                                                    <i class="bi bi-link-45deg me-1"></i> Learn More
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .certificate-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .certificate-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .nav-pills .nav-link {
            color: #94a3b8;
            border-radius: 20px;
            padding: 0.75rem 1.5rem;
        }
        .nav-pills .nav-link.active {
            background-color: var(--primary-color);
        }
    </style>
}
