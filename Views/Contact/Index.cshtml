@model ContactViewModel
@{
    ViewData["Title"] = "Contact";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Get In Touch</h1>
        <p class="lead text-muted">I'd love to hear from you. Let's discuss your next project!</p>
    </div>

    <div class="row g-5">
        <!-- Contact Info -->
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body p-4">
                    <h4 class="mb-4">Contact Information</h4>

                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="d-flex align-items-center mb-4">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                                <i class="bi bi-envelope fs-4 text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Email</small>
                                <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="d-flex align-items-center mb-4">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                                <i class="bi bi-telephone fs-4 text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Phone</small>
                                <a href="tel:@Model.Phone" class="text-decoration-none">@Model.Phone</a>
                            </div>
                        </div>
                    }

                    @if (Model.SocialLinks.Any())
                    {
                        <hr class="my-4">
                        <h5 class="mb-3">Connect With Me</h5>
                        <div class="d-flex gap-3 flex-wrap">
                            @foreach (var social in Model.SocialLinks)
                            {
                                <a href="@social.Url" target="_blank" class="btn btn-outline-primary">
                                    <i class="bi @social.Icon me-2"></i>@social.Platform
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body p-4">
                    <h4 class="mb-4">Send a Message</h4>

                    @if (Model.MessageSent)
                    {
                        <div class="alert alert-success d-flex align-items-center" role="alert">
                            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Message sent successfully!</strong> I'll get back to you as soon as possible.
                            </div>
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Form.Name" class="form-label">Your Name</label>
                            <input asp-for="Form.Name" class="form-control bg-dark text-white border-secondary" placeholder="John Doe" />
                            <span asp-validation-for="Form.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.Email" class="form-label">Email Address</label>
                            <input asp-for="Form.Email" class="form-control bg-dark text-white border-secondary" placeholder="john@example.com" />
                            <span asp-validation-for="Form.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.Message" class="form-label">Message</label>
                            <textarea asp-for="Form.Message" class="form-control bg-dark text-white border-secondary" rows="5" placeholder="Tell me about your project..."></textarea>
                            <span asp-validation-for="Form.Message" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-send me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
