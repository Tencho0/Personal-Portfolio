@model HomeViewModel
@{
    ViewData["Title"] = "About Me";
}

<!-- Hero Section -->
<section class="hero-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-4 text-center mb-4 mb-lg-0">
                <img src="@Model.ProfileImagePath" alt="@Model.ProfileName" class="profile-image" onerror="this.src='/images/profile-placeholder.png'">
            </div>
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold mb-2">@Model.ProfileName</h1>
                <p class="lead text-muted mb-4">@Model.ProfileTitle</p>
                <p class="mb-4">@Model.ProfileBio</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Contact" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="bi bi-envelope me-2"></i>Contact Me
                    </a>
                    <a asp-controller="Portfolio" asp-action="Index" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-folder me-2"></i>View Portfolio
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Metrics Section -->
@if (Model.Metrics.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                @foreach (var metric in Model.Metrics)
                {
                    <div class="col-6 col-md-3">
                        <div class="card metric-card h-100">
                            <i class="bi @metric.Icon fs-1 text-primary mb-2"></i>
                            <div class="metric-value">@metric.Value</div>
                            <div class="text-muted">@metric.Label</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Tech Stack Section -->
@if (Model.TechStack.Any())
{
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-4">Tech Stack</h2>
            <div class="text-center">
                @foreach (var tech in Model.TechStack)
                {
                    <span class="tech-badge">
                        @if (!string.IsNullOrEmpty(tech.LogoPath))
                        {
                            <img src="@tech.LogoPath" alt="@tech.Name" style="height: 20px; margin-right: 5px;">
                        }
                        @tech.Name
                    </span>
                }
            </div>
        </div>
    </section>
}

<!-- Testimonials Section -->
@if (Model.FeaturedReviews.Any())
{
    <section class="py-5 bg-dark bg-opacity-50">
        <div class="container">
            <h2 class="text-center mb-5">What Clients Say</h2>
            <div class="row g-4">
                @foreach (var review in Model.FeaturedReviews)
                {
                    <div class="col-md-4">
                        <div class="card h-100 p-4">
                            <div class="d-flex align-items-center mb-3">
                                @if (!string.IsNullOrEmpty(review.PhotoPath))
                                {
                                    <img src="@review.PhotoPath" alt="@review.Name" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                        <i class="bi bi-person fs-4"></i>
                                    </div>
                                }
                                <div>
                                    <h6 class="mb-0">@review.Name</h6>
                                    @if (!string.IsNullOrEmpty(review.Source))
                                    {
                                        <small class="text-muted">@review.Source</small>
                                    }
                                </div>
                            </div>
                            @if (review.StarRating.HasValue)
                            {
                                <div class="star-rating mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= review.StarRating ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                            }
                            <p class="mb-0 fst-italic">"@review.Text"</p>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Reviews" asp-action="Index" class="btn btn-outline-primary">
                    View All Reviews <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>
}

<!-- Blog Preview Section -->
@if (Model.LatestPosts.Any())
{
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Latest Blog Posts</h2>
            <div class="row g-4">
                @foreach (var post in Model.LatestPosts)
                {
                    <div class="col-md-4">
                        <div class="card h-100">
                            @if (!string.IsNullOrEmpty(post.CoverImagePath))
                            {
                                <img src="@post.CoverImagePath" class="card-img-top" alt="@post.Title" style="height: 150px; object-fit: cover;">
                            }
                            <div class="card-body">
                                @if (!string.IsNullOrEmpty(post.Category))
                                {
                                    <span class="badge bg-primary mb-2">@post.Category</span>
                                }
                                <h5 class="card-title">@post.Title</h5>
                                <p class="card-text text-muted">@(post.PreviewText ?? post.MarkdownContent.Substring(0, Math.Min(100, post.MarkdownContent.Length)))...</p>
                                <a asp-controller="Blog" asp-action="Detail" asp-route-slug="@post.Slug" class="btn btn-sm btn-outline-primary">
                                    Read More <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                            <div class="card-footer text-muted small">
                                <i class="bi bi-calendar me-1"></i> @post.PublishedAt?.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Blog" asp-action="Index" class="btn btn-outline-primary">
                    View All Posts <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>
}
