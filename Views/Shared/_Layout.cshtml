<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2563eb;
            --secondary-color: #1e40af;
            --dark-bg: #0f172a;
            --card-bg: #1e293b;
        }

        body {
            background-color: var(--dark-bg);
            color: #e2e8f0;
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--card-bg) !important;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .navbar-brand {
            font-weight: 700;
            color: #fff !important;
        }

        .nav-link {
            color: #94a3b8 !important;
            transition: color 0.2s;
        }

        .nav-link:hover, .nav-link.active {
            color: #fff !important;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .btn-primary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
        }

        .btn-outline-primary {
            color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .btn-outline-primary:hover {
            background-color: var(--primary-color);
            color: #fff;
        }

        .text-muted {
            color: #94a3b8 !important;
        }

        h1, h2, h3, h4, h5, h6 {
            color: #f8fafc;
        }

        .card-title {
            color: #f8fafc;
        }

        .card-text {
            color: #cbd5e1;
        }

        p {
            color: #e2e8f0;
        }

        .form-label {
            color: #f1f5f9;
            font-weight: 500;
        }

        .form-control {
            background-color: #334155;
            border-color: #475569;
            color: #ffffff;
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .form-control:focus {
            background-color: #334155;
            border-color: var(--primary-color);
            color: #ffffff;
            box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.25);
        }

        a {
            color: #60a5fa;
        }

        a:hover {
            color: #93c5fd;
        }

        footer {
            background-color: var(--card-bg);
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .hero-section {
            background: linear-gradient(135deg, var(--dark-bg) 0%, var(--card-bg) 100%);
        }

        .metric-card {
            text-align: center;
            padding: 1.5rem;
        }

        .metric-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        .tech-badge {
            display: inline-block;
            padding: 0.5rem 1rem;
            background-color: rgba(37, 99, 235, 0.2);
            border: 1px solid var(--primary-color);
            border-radius: 20px;
            margin: 0.25rem;
            font-size: 0.875rem;
            color: #93c5fd;
        }

        .profile-image {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--primary-color);
        }

        .star-rating {
            color: #fbbf24;
        }

        .project-card img {
            height: 200px;
            object-fit: cover;
        }

        .blog-preview {
            border-left: 3px solid var(--primary-color);
            padding-left: 1rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-code-slash me-2"></i>Portfolio
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Portfolio" ? "active" : "")"
                           asp-controller="Portfolio" asp-action="Index">Portfolio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")"
                           asp-controller="Blog" asp-action="Index">Blog</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reviews" ? "active" : "")"
                           asp-controller="Reviews" asp-action="Index">Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Certificates" ? "active" : "")"
                           asp-controller="Certificates" asp-action="Index">Certificates</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")"
                           asp-controller="Contact" asp-action="Index">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0 text-muted">&copy; @DateTime.Now.Year Portfolio. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
