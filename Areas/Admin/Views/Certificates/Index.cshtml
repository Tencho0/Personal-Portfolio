@model List<Certificate>
@{
    ViewData["Title"] = "Certificates";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Certificates</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus me-1"></i>Add Certificate
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-award display-1 text-muted"></i>
                <p class="lead text-muted mt-3">No certificates yet.</p>
                <a asp-action="Create" class="btn btn-primary">Add your first certificate</a>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">
                <i class="bi bi-info-circle me-1"></i>Drag and drop rows to reorder certificates.
            </p>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Issuer</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="sortable-certificates">
                        @foreach (var cert in Model)
                        {
                            <tr data-id="@cert.Id">
                                <td class="sortable-handle">
                                    <i class="bi bi-grip-vertical fs-5"></i>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(cert.ImagePath))
                                    {
                                        <img src="@cert.ImagePath" alt="@cert.Title" class="rounded" style="width: 60px; height: 40px; object-fit: contain;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width: 60px; height: 40px;">
                                            <i class="bi bi-award text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@cert.Title</strong>
                                    <br><small class="text-muted">/certificates/@cert.Slug</small>
                                </td>
                                <td>@cert.Issuer</td>
                                <td>@cert.DateEarned.ToString("MMM yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@cert.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="/certificates/@cert.Slug" target="_blank" class="btn btn-outline-secondary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@cert.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    <!-- Delete Modal -->
                                    <div class="modal fade" id="deleteModal-@cert.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content bg-dark">
                                                <div class="modal-header border-secondary">
                                                    <h5 class="modal-title">Delete Certificate</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    Are you sure you want to delete "<strong>@cert.Title</strong>"?
                                                </div>
                                                <div class="modal-footer border-secondary">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <form asp-action="Delete" asp-route-id="@cert.Id" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sortable = new Sortable(document.getElementById('sortable-certificates'), {
                handle: '.sortable-handle',
                animation: 150,
                ghostClass: 'sortable-ghost',
                onEnd: function() {
                    const ids = Array.from(document.querySelectorAll('#sortable-certificates tr'))
                        .map(row => parseInt(row.dataset.id));

                    fetch('@Url.Action("UpdatePositions")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(ids)
                    });
                }
            });
        });
    </script>
}
