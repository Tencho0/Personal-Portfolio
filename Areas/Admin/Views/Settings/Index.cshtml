@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
    var metrics = ViewBag.Metrics as List<Metric> ?? new List<Metric>();
    var techStack = ViewBag.TechStack as List<TechStackItem> ?? new List<TechStackItem>();
    var socialLinks = ViewBag.SocialLinks as List<SocialLink> ?? new List<SocialLink>();
}

<h1 class="h3 mb-4">Settings</h1>

<!-- Profile Settings -->
<div class="card mb-4">
    <div class="card-header bg-transparent">
        <h5 class="mb-0"><i class="bi bi-person me-2"></i>Profile Settings</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="ProfileName" class="form-label">Name</label>
                        <input asp-for="ProfileName" class="form-control" placeholder="Your name" />
                        <span asp-validation-for="ProfileName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProfileTitle" class="form-label">Title</label>
                        <input asp-for="ProfileTitle" class="form-control" placeholder="e.g., Software Engineer" />
                        <span asp-validation-for="ProfileTitle" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProfileBio" class="form-label">Bio</label>
                        <textarea asp-for="ProfileBio" class="form-control" rows="4" placeholder="Tell visitors about yourself"></textarea>
                        <span asp-validation-for="ProfileBio" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="ContactEmail" class="form-control" placeholder="your@email.com" />
                            <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="ContactPhone" class="form-control" placeholder="+1 (555) 123-4567" />
                            <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Profile Image</label>
                    @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                    {
                        <div class="mb-2 text-center">
                            <img src="@Model.ProfileImagePath" alt="Profile" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                        </div>
                    }
                    <input type="file" name="profileImage" class="form-control" accept="image/*" id="profileImageInput" />
                    <div id="profileImagePreview" class="mt-2 text-center"></div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check me-1"></i>Save Profile
            </button>
        </form>
    </div>
</div>

<!-- Metrics -->
<div class="card mb-4">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Metrics</h5>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addMetricModal">
            <i class="bi bi-plus"></i> Add
        </button>
    </div>
    <div class="card-body">
        @if (!metrics.Any())
        {
            <p class="text-muted mb-0">No metrics added yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Icon</th>
                            <th>Label</th>
                            <th>Value</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var metric in metrics)
                        {
                            <tr>
                                <td><i class="bi @metric.Icon fs-5"></i></td>
                                <td>@metric.Label</td>
                                <td>@metric.Value</td>
                                <td>
                                    <form asp-action="DeleteMetric" asp-route-id="@metric.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this metric?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Tech Stack -->
<div class="card mb-4">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-code-slash me-2"></i>Tech Stack</h5>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addTechModal">
            <i class="bi bi-plus"></i> Add
        </button>
    </div>
    <div class="card-body">
        @if (!techStack.Any())
        {
            <p class="text-muted mb-0">No technologies added yet.</p>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var tech in techStack)
                {
                    <div class="d-flex align-items-center rounded px-3 py-2" style="background-color: #334155; border: 1px solid #475569;">
                        @if (!string.IsNullOrEmpty(tech.LogoPath))
                        {
                            <img src="@tech.LogoPath" alt="@tech.Name" style="height: 20px; margin-right: 8px;">
                        }
                        <span style="color: #f1f5f9;">@tech.Name</span>
                        <form asp-action="DeleteTechStack" asp-route-id="@tech.Id" method="post" class="d-inline ms-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link btn-sm text-danger p-0" onclick="return confirm('Delete this technology?')">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Social Links -->
<div class="card mb-4">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-share me-2"></i>Social Links</h5>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addSocialModal">
            <i class="bi bi-plus"></i> Add
        </button>
    </div>
    <div class="card-body">
        @if (!socialLinks.Any())
        {
            <p class="text-muted mb-0">No social links added yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Icon</th>
                            <th>Platform</th>
                            <th>URL</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var social in socialLinks)
                        {
                            <tr>
                                <td><i class="bi @social.Icon fs-5"></i></td>
                                <td>@social.Platform</td>
                                <td><a href="@social.Url" target="_blank" class="text-decoration-none">@social.Url</a></td>
                                <td>
                                    <form asp-action="DeleteSocialLink" asp-route-id="@social.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this link?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Add Metric Modal -->
<div class="modal fade" id="addMetricModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark">
            <form asp-action="AddMetric" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Add Metric</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Label</label>
                        <input name="label" class="form-control" required placeholder="e.g., Projects Completed" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Value</label>
                        <input name="value" class="form-control" required placeholder="e.g., 50+" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Icon (Bootstrap Icons)</label>
                        <input name="icon" class="form-control" placeholder="e.g., bi-folder-check" />
                        <small class="text-muted">Find icons at <a href="https://icons.getbootstrap.com" target="_blank">icons.getbootstrap.com</a></small>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Metric</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Tech Modal -->
<div class="modal fade" id="addTechModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark">
            <form asp-action="AddTechStack" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Add Technology</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="name" class="form-control" required placeholder="e.g., React" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL (optional)</label>
                        <input name="url" class="form-control" placeholder="https://reactjs.org" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Logo (optional)</label>
                        <input name="logo" type="file" class="form-control" accept="image/*" />
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Technology</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Social Modal -->
<div class="modal fade" id="addSocialModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark">
            <form asp-action="AddSocialLink" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Add Social Link</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Platform</label>
                        <input name="platform" class="form-control" required placeholder="e.g., LinkedIn" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL</label>
                        <input name="url" class="form-control" required placeholder="https://linkedin.com/in/yourprofile" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Icon (Bootstrap Icons)</label>
                        <input name="icon" class="form-control" placeholder="e.g., bi-linkedin" />
                        <small class="text-muted">Find icons at <a href="https://icons.getbootstrap.com" target="_blank">icons.getbootstrap.com</a></small>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Link</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('profileImageInput').addEventListener('change', function(e) {
            const preview = document.getElementById('profileImagePreview');
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML = `<img src="${e.target.result}" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;" alt="Preview">`;
                };
                reader.readAsDataURL(file);
            } else {
                preview.innerHTML = '';
            }
        });
    </script>
}
