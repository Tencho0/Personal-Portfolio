<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2563eb;
            --secondary-color: #1e40af;
            --dark-bg: #0f172a;
            --sidebar-bg: #1e293b;
            --card-bg: #1e293b;
        }

        body {
            background-color: var(--dark-bg);
            color: #e2e8f0;
            min-height: 100vh;
        }

        .sidebar {
            background-color: var(--sidebar-bg);
            min-height: 100vh;
            width: 260px;
            position: fixed;
            top: 0;
            left: 0;
            padding-top: 1rem;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-brand {
            padding: 1rem 1.5rem;
            font-weight: 700;
            font-size: 1.25rem;
            color: #fff;
            text-decoration: none;
            display: block;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 1rem;
        }

        .sidebar-nav {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar-nav .nav-item {
            margin: 0.25rem 0.75rem;
        }

        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            color: #94a3b8;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            background-color: var(--primary-color);
            color: #fff;
        }

        .sidebar-nav .nav-link i {
            margin-right: 0.75rem;
            font-size: 1.1rem;
        }

        .main-content {
            margin-left: 260px;
            padding: 2rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .btn-primary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
        }

        .table {
            color: #e2e8f0;
        }

        .table thead th {
            border-bottom: 2px solid rgba(255,255,255,0.1);
        }

        .table td, .table th {
            border-color: rgba(255,255,255,0.05);
            vertical-align: middle;
        }

        .form-label {
            color: #f1f5f9;
            font-weight: 500;
        }

        .form-control, .form-select {
            background-color: #334155;
            border-color: #475569;
            color: #ffffff;
        }

        .form-control:focus, .form-select:focus {
            background-color: #334155;
            border-color: var(--primary-color);
            color: #ffffff;
            box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.25);
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .form-check-label {
            color: #e2e8f0;
        }

        .card-header {
            color: #f1f5f9;
        }

        .card-title {
            color: #f8fafc;
        }

        h1, h2, h3, h4, h5, h6 {
            color: #f8fafc;
        }

        .text-muted {
            color: #94a3b8 !important;
        }

        a {
            color: #60a5fa;
        }

        a:hover {
            color: #93c5fd;
        }

        .badge-draft {
            background-color: #f59e0b;
        }

        .badge-published {
            background-color: #10b981;
        }

        .stat-card {
            text-align: center;
            padding: 1.5rem;
        }

        .stat-card .stat-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        .sortable-handle {
            cursor: move;
            color: #64748b;
        }

        .sortable-ghost {
            opacity: 0.5;
            background: var(--primary-color);
        }

        .markdown-preview {
            background-color: var(--dark-bg);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 1rem;
            min-height: 300px;
            color: #e2e8f0;
        }

        .markdown-preview h1, .markdown-preview h2, .markdown-preview h3, .markdown-preview h4, .markdown-preview h5, .markdown-preview h6 {
            margin-top: 1rem;
            margin-bottom: 0.5rem;
            color: #f8fafc;
        }

        .markdown-preview p {
            margin-bottom: 0.75rem;
            color: #e2e8f0;
        }

        .markdown-preview li {
            color: #e2e8f0;
        }

        .markdown-preview strong {
            color: #f8fafc;
        }

        .markdown-preview code {
            background-color: rgba(255,255,255,0.15);
            padding: 0.2rem 0.4rem;
            border-radius: 4px;
            color: #fbbf24;
        }

        .markdown-preview pre {
            background-color: #0d1117;
            padding: 1rem;
            border-radius: 8px;
            overflow-x: auto;
        }

        .markdown-preview pre code {
            background: none;
            color: #e2e8f0;
        }

        .markdown-preview a {
            color: #60a5fa;
        }

        .markdown-preview table {
            color: #e2e8f0;
        }

        .markdown-preview th {
            color: #f8fafc;
        }

        .markdown-preview blockquote {
            border-left: 4px solid var(--primary-color);
            padding-left: 1rem;
            margin-left: 0;
            color: #cbd5e1;
        }

        .upload-preview {
            max-width: 200px;
            max-height: 150px;
            object-fit: cover;
            border-radius: 8px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <a class="sidebar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2 me-2"></i>Admin Panel
        </a>
        <ul class="sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")"
                   asp-area="Admin" asp-controller="Projects" asp-action="Index">
                    <i class="bi bi-folder"></i> Projects
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")"
                   asp-area="Admin" asp-controller="Blog" asp-action="Index">
                    <i class="bi bi-journal-text"></i> Blog Posts
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reviews" ? "active" : "")"
                   asp-area="Admin" asp-controller="Reviews" asp-action="Index">
                    <i class="bi bi-chat-quote"></i> Reviews
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Certificates" ? "active" : "")"
                   asp-area="Admin" asp-controller="Certificates" asp-action="Index">
                    <i class="bi bi-award"></i> Certificates
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Awards" ? "active" : "")"
                   asp-area="Admin" asp-controller="Awards" asp-action="Index">
                    <i class="bi bi-trophy"></i> Awards
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Messages" ? "active" : "")"
                   asp-area="Admin" asp-controller="Messages" asp-action="Index">
                    <i class="bi bi-envelope"></i> Messages
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
                   asp-area="Admin" asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-gear"></i> Settings
                </a>
            </li>
            <hr class="mx-3 my-3 border-secondary">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index" asp-area="">
                    <i class="bi bi-box-arrow-up-right"></i> View Site
                </a>
            </li>
            <li class="nav-item">
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link w-100 text-start border-0 bg-transparent">
                        <i class="bi bi-box-arrow-left"></i> Logout
                    </button>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
